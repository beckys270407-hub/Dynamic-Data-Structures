//Realizar un programa que divida una lista en N listas mas pequegnas de M nodos cada una (si la division no es exacta rellenas los espaciones vacios con un valor por defeto)

#include <iostream>
using namespace std;

struct Node {
    int data;
    Node* next;
    Node(int value) : data(value), next(nullptr) {}
};

int main() {
    Node* dummy = new Node(0);
    Node* tail = dummy;
    int total, n, m;

    cout << "How many nodes do you want to add? ";
    cin >> total;

    cout << "\n";

    for (int i = 0; i < total; i++) {
        int val;
        cout << "Enter value for node: ";
        cin >> val;
        tail->next = new Node(val);
        tail = tail->next;
    }

    cout << "\n";

    cout << "Enter the number of sublists (N): ";
    cin >> n;
    cout << "Enter the number of nodes per sublist (M): ";
    cin >> m;

    Node* current = dummy->next;
    cout << "\n--- Splitting Results ---" << endl;

    cout << "\n";

    for (int i = 0; i < n; i++) {
        cout << "Sublist " << i + 1 << ": ";
        for (int j = 0; j < m; j++) {
            if (current != nullptr) {
                cout << "[" << current->data << "] ";
                current = current->next;
            } else {
                cout << "[0] "; 
            }
        }
            cout << endl;
    }
            return 0;
}
